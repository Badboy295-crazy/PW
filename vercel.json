{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/cron-solve",
      "destination": "/api/cron-solve.js"
    },
    {
      "source": "/api/get-tokens",
      "destination": "/api/get-tokens.js"
    },
    {
      "source": "/api/save-tokens",
      "destination": "/api/save-tokens.js"
    },
    {
      "source": "/verify",
      "destination": "/verify.html"
    },
    {
      "source": "/(.*)",
      "destination": "/api/index.js"
    }
  ]
}
