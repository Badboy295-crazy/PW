{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/cron-solve",
      "destination": "/api/cron-solve.js"
    },
    {
      "source": "/api/get-tokens",
      "destination": "/api/get-tokens.js"
    },
    {
      "source": "/api/save-tokens",
      "destination": "/api/save-tokens.js"
    },
    {
      "source": "/verify",
      "destination": "/verify.html"
    },
    {
      "source": "/_next/:path*",
      "destination": "https://deltastudy.site/_next/:path*"
    },
    {
      "source": "/static/:path*",
      "destination": "https://deltastudy.site/static/:path*"
    },
    {
      "source": "/favicon.ico",
      "destination": "https://deltastudy.site/favicon.ico"
    },
    {
      "source": "/(.*)",
      "destination": "/api/index.js"
    }
  ]
}
